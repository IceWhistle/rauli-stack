{
  "name": "deadlock-counter",
  "version": "4.0.0",
  "description": "Deadlock hero counter picker - Advanced overlay with build paths, synergy detection, and match history",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --dir",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "security": "npm audit && echo '✓ No vulnerabilities found'",
    "precommit": "npm run lint && npm run test && npm run security"
  },
  "author": "Rauli",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "jest": "^29.7.0",
    "eslint": "^8.56.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/test/**/*.test.js"],
    "collectCoverageFrom": ["counter-logic.js"]
  },
  "build": {
    "appId": "com.deadlock.counter",
    "productName": "DeadlockCounter",
    "win": { "target": "dir" },
    "files": ["main.js", "counter-logic.js", "overlay.html"],
    "extraMetadata": {
      "version": "4.0.0"
    }
  }
}
